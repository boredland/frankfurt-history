{
  "name": "frankfurt-history",
  "main": "app/src/worker.ts",
  "compatibility_date": "2026-04-26",
  "assets": {
    "directory": "app/dist/client",
    "not_found_handling": "single-page-application"
  },
  "r2_buckets": [
    {
      "binding": "R2_BUCKET",
      "bucket_name": "frankfurt-history-assets"
    }
  ],
  "build": {
    "command": "cd app && bun install && bun run build"
  }
}
