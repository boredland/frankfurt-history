{
  "name": "frankfurt-history",
  "main": "app/src/worker.ts",
  "compatibility_date": "2026-04-26",
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "history.jonas-strassel.de",
      "zone_name": "jonas-strassel.de",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "app/dist/client",
    "not_found_handling": "single-page-application"
  },
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "frankfurt-history-assets"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "logs": {
      "enabled": true
    }
  },
  "build": {
    "command": "cd app && bun install && bun run build"
  }
}
