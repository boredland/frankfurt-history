{
  "name": "frankfurt-history-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build:data": "cd .. && uv run python3 scripts/geojson.py",
    "dev": "bun run build:data && vite dev",
    "build": "bun run build:data && vite build",
    "start": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "check": "bun run typecheck && bun run lint"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@tailwindcss/vite": "^4.2.4",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.4",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@tanstack/intent": "^0.0.36",
    "@tanstack/react-router": "^1.168.24",
    "@tanstack/react-start": "^1.167.49",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-map-gl": "^8.1.1",
    "vinxi": "^0.5.11",
    "vite": "^8.0.10",
    "zod": "^4.3.6"
  }
}
